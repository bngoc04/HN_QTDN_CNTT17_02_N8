<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Tree View -->
        <record id="view_hr_luong_co_ban_tree" model="ir.ui.view">
            <field name="name">hr.luong.co.ban.tree</field>
            <field name="model">hr_luong_co_ban</field>
            <field name="arch" type="xml">
                <tree string="Lương cơ bản">
                    <field name="nhan_vien_id"/>
                    <field name="ma_dinh_danh"/>
                    <field name="luong_co_ban" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                    <field name="phu_cap_an_trua" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                    <field name="phu_cap_trach_nhiem" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                </tree>
            </field>
        </record>

        <!-- Form View -->
        <record id="view_hr_luong_co_ban_form" model="ir.ui.view">
            <field name="name">hr.luong.co.ban.form</field>
            <field name="model">hr_luong_co_ban</field>
            <field name="arch" type="xml">
                <form string="Cấu hình lương cơ bản">
                    <sheet>
                        <div class="oe_title">
                            <h1>Cấu hình lương cơ bản</h1>
                        </div>
                        <group>
                            <group string="Thông tin nhân viên">
                                <field name="nhan_vien_id"/>
                                <field name="ma_dinh_danh"/>
                            </group>
                            <group string="Chi tiết lương &amp; phụ cấp">
                                <field name="luong_co_ban"/>
                                <field name="phu_cap_an_trua"/>
                                <field name="phu_cap_trach_nhiem"/>
                            </group>
                        </group>
                        <group string="Ghi chú">
                            <field name="ghi_chu"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Search View -->
        <record id="view_hr_luong_co_ban_search" model="ir.ui.view">
            <field name="name">hr.luong.co.ban.search</field>
            <field name="model">hr_luong_co_ban</field>
            <field name="arch" type="xml">
                <search string="Tìm kiếm cấu hình lương">
                    <field name="nhan_vien_id"/>
                    <field name="ma_dinh_danh"/>
                </search>
            </field>
        </record>

        <!-- Action -->
        <record id="action_hr_luong_co_ban" model="ir.actions.act_window">
            <field name="name">Lương cơ bản</field>
            <field name="res_model">hr_luong_co_ban</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_hr_luong_co_ban_search"/>
        </record>
    </data>
</odoo>
