<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Tree View -->
        <record id="view_hr_cham_cong_tree" model="ir.ui.view">
            <field name="name">hr.cham.cong.tree</field>
            <field name="model">hr_cham_cong</field>
            <field name="arch" type="xml">
                <tree string="Bảng chấm công hàng ngày" editable="top">
                    <field name="nhan_vien_id"/>
                    <field name="ngay_cham_cong"/>
                    <field name="trang_thai"/>
                    <field name="so_gio_tang_ca"/>
                    <field name="nguoi_xac_nhan"/>
                </tree>
            </field>
        </record>

        <!-- Form View -->
        <record id="view_hr_cham_cong_form" model="ir.ui.view">
            <field name="name">hr.cham.cong.form</field>
            <field name="model">hr_cham_cong</field>
            <field name="arch" type="xml">
                <form string="Chấm công hàng ngày">
                    <sheet>
                        <div class="oe_title">
                            <h1>Thông tin chấm công</h1>
                        </div>
                        <group>
                            <group>
                                <field name="nhan_vien_id"/>
                                <field name="ngay_cham_cong"/>
                            </group>
                            <group>
                                <field name="trang_thai"/>
                                <field name="so_gio_tang_ca"/>
                                <field name="nguoi_xac_nhan"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Search View -->
        <record id="view_hr_cham_cong_search" model="ir.ui.view">
            <field name="name">hr.cham.cong.search</field>
            <field name="model">hr_cham_cong</field>
            <field name="arch" type="xml">
                <search string="Tìm kiếm chấm công">
                    <field name="nhan_vien_id"/>
                    <field name="ngay_cham_cong"/>
                    <filter string="Đi làm" name="di_lam" domain="[('trang_thai', '=', 'di_lam')]"/>
                    <filter string="Nửa ngày" name="nua_ngay" domain="[('trang_thai', '=', 'nua_ngay')]"/>
                    <filter string="Nghỉ có phép" name="nghi_co_phep" domain="[('trang_thai', '=', 'nghi_co_phep')]"/>
                    <filter string="Nghỉ không phép" name="nghi_khong_phep" domain="[('trang_thai', '=', 'nghi_khong_phep')]"/>
                    <group expand="0" string="Gom nhóm">
                        <filter string="Nhân viên" name="group_by_nhan_vien" context="{'group_by':'nhan_vien_id'}"/>
                        <filter string="Ngày chấm công" name="group_by_ngay" context="{'group_by':'ngay_cham_cong'}"/>
                        <filter string="Trạng thái" name="group_by_trang_thai" context="{'group_by':'trang_thai'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Action -->
        <record id="action_hr_cham_cong" model="ir.actions.act_window">
            <field name="name">Chấm công hàng ngày</field>
            <field name="res_model">hr_cham_cong</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_hr_cham_cong_search"/>
        </record>
    </data>
</odoo>
