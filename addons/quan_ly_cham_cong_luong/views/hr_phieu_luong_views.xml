<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Tree View -->
        <record id="view_hr_phieu_luong_tree" model="ir.ui.view">
            <field name="name">hr.phieu.luong.tree</field>
            <field name="model">hr_phieu_luong</field>
            <field name="arch" type="xml">
                <tree string="Phiếu lương tháng">
                    <field name="nhan_vien_id"/>
                    <field name="thang"/>
                    <field name="nam"/>
                    <field name="so_ngay_di_lam"/>
                    <field name="luong_co_ban" widget="monetary"/>
                    <field name="phu_cap" widget="monetary"/>
                    <field name="khen_thuong" widget="monetary"/>
                    <field name="ky_luat" widget="monetary"/>
                    <field name="thuc_linh" widget="monetary"/>
                </tree>
            </field>
        </record>

        <!-- Form View -->
        <record id="view_hr_phieu_luong_form" model="ir.ui.view">
            <field name="name">hr.phieu.luong.form</field>
            <field name="model">hr_phieu_luong</field>
            <field name="arch" type="xml">
                <form string="Phiếu lương tháng">
                    <header>
                        <button name="action_recompute" string="Tính lại lương" type="object" class="oe_highlight"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>Phiếu Lương Nhân Viên</h1>
                        </div>
                        <group>
                            <group string="Thông tin chung">
                                <field name="nhan_vien_id"/>
                                <field name="thang"/>
                                <field name="nam"/>
                            </group>
                            <group string="Dữ liệu chấm công">
                                <field name="so_ngay_di_lam"/>
                            </group>
                        </group>
                        <group>
                            <group string="Các khoản thu nhập (VND)">
                                <field name="luong_co_ban" readonly="1"/>
                                <field name="phu_cap" readonly="1"/>
                                <field name="khen_thuong" readonly="1"/>
                            </group>
                            <group string="Các khoản giảm trừ &amp; thực nhận (VND)">
                                <field name="ky_luat" readonly="1"/>
                                <hr style="grid-column: span 2;"/>
                                <field name="thuc_linh" class="oe_subtotal_footer_separator" style="font-weight: bold; font-size: 1.2em; color: #2C3E50;" readonly="1"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Search View -->
        <record id="view_hr_phieu_luong_search" model="ir.ui.view">
            <field name="name">hr.phieu.luong.search</field>
            <field name="model">hr_phieu_luong</field>
            <field name="arch" type="xml">
                <search string="Tìm kiếm phiếu lương">
                    <field name="nhan_vien_id"/>
                    <field name="thang"/>
                    <field name="nam"/>
                    <group expand="0" string="Gom nhóm">
                        <filter string="Nhân viên" name="group_by_nhan_vien" context="{'group_by':'nhan_vien_id'}"/>
                        <filter string="Tháng" name="group_by_thang" context="{'group_by':'thang'}"/>
                        <filter string="Năm" name="group_by_nam" context="{'group_by':'nam'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Action -->
        <record id="action_hr_phieu_luong" model="ir.actions.act_window">
            <field name="name">Phiếu lương tháng</field>
            <field name="res_model">hr_phieu_luong</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_hr_phieu_luong_search"/>
        </record>
    </data>
</odoo>
